{
  "name": "brick-erp",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @brick/db generate",
    "db:migrate": "pnpm --filter @brick/db migrate",
    "db:push": "pnpm --filter @brick/db push",
    "db:seed": "pnpm --filter @brick/db seed",
    "db:studio": "pnpm --filter @brick/db studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
