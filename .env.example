# ─── Database (Railway PostgreSQL) ───
# Local docker-compose maps Postgres to host port 5433 (avoids clashing with a
# native Postgres on 5432). On Railway, use the injected DATABASE_URL instead.
DATABASE_URL="postgresql://brick:brick@localhost:5433/brick_erp?schema=public"

# ─── Redis (Railway) ───
REDIS_URL="redis://localhost:6379"

# ─── JWT ───
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ─── API ───
API_PORT=4000
API_PREFIX="api/v1"
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# ─── Throttling ───
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ─── S3 / R2 storage (Phase 4+) ───
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET="brick-erp"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ─── Web (Next.js) ───
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
