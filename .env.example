# ─── Database (Postgres — Neon in production) ───
# Local docker-compose maps Postgres to host port 5433 (avoids clashing with a
# native Postgres on 5432). In production use a POOLED connection string here
# (e.g. the Neon "-pooler" host) so serverless functions don't exhaust connections.
DATABASE_URL="postgresql://brick:brick@localhost:5433/brick_erp?schema=public"
# Direct (unpooled) connection used only for `prisma migrate`. Locally it can be
# the same as DATABASE_URL; on Neon use the non-pooler host.
DIRECT_URL="postgresql://brick:brick@localhost:5433/brick_erp?schema=public"

# ─── JWT ───
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ─── API ───
API_PORT=4000
API_PREFIX="api/v1"
# In production set this to the deployed web origin, e.g. https://brick-web.vercel.app
CORS_ORIGIN="http://localhost:3000"
NODE_ENV="development"

# ─── Throttling ───
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ─── S3 / R2 storage (generated PDFs) ───
# Cloudflare R2 example:
#   S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
#   S3_REGION="auto"
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET="brick-erp"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Optional public/CDN base for objects; if empty, presigned URLs are used.
S3_PUBLIC_URL=""

# ─── Cron (Vercel Cron → daily alert refresh) ───
# Vercel sends "Authorization: Bearer <CRON_SECRET>" to /api/v1/cron/refresh-alerts.
CRON_SECRET="change-me-cron-secret"

# ─── Web (Next.js) ───
# In production set this to the deployed API origin, e.g. https://brick-api.vercel.app/api/v1
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
