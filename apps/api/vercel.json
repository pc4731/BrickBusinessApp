{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "outputDirectory": "public",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile --prod=false",
  "buildCommand": "cd ../.. && pnpm --filter @brick/db generate && pnpm --filter @brick/db migrate:deploy && pnpm turbo run build --filter=@brick/api...",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "../../node_modules/.pnpm/@prisma+client@*/node_modules/@prisma/client/**"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "crons": [{ "path": "/api/v1/cron/refresh-alerts", "schedule": "0 2 * * *" }]
}
